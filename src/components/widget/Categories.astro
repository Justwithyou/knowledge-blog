---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getCategoryList } from "../../utils/content-utils";
import ButtonLink from "../control/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";

const categories = await getCategoryList();

const COLLAPSED_HEIGHT = "5rem";
const COLLAPSE_THRESHOLD = 5;

const isCollapsed = categories.length >= COLLAPSE_THRESHOLD;

// Calculate visual width: Chinese chars ~16px, English/numbers ~8px (relative units)
// Column width is roughly 7.5rem = 120px at base font
// Using units where 1 Chinese = 2, 1 English = 1
const getVisualWidth = (str: string): number => {
    let width = 0;
    for (const char of str) {
        if (/[\u4e00-\u9fa5]/.test(char)) {
            width += 2; // Chinese character
        } else {
            width += 1; // English/number/symbol
        }
    }
    return width;
};

// If any category visual width > 12 units, use single column to prevent wrapping
// Account for badge (e.g. " (12)") which takes ~4 units
const useSingleColumn = categories.some(c => getVisualWidth(c.name) > 12);

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.categories)} id="categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
>
    <div class:list={["categories-grid", { "single-column": useSingleColumn }]}>
        {categories.map((c) => {
            const hue = (c.name.charCodeAt(0) * 37 + c.name.charCodeAt(c.name.length - 1) * 13) % 360;
            return (
                <ButtonLink
                    href={c.url}
                    label={`View all posts in the ${c.name.trim()} category`}
                    hue={hue}
                >
                    {c.name.trim()}
                </ButtonLink>
            );
        })}
    </div>
</WidgetLayout>

<style>
    .categories-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem;
    }

    .categories-grid.single-column {
        grid-template-columns: 1fr;
    }
</style>
