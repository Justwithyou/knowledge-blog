---
import type { MarkdownHeading } from "astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const className = Astro.props.class;
---
<div id="sidebar" class:list={[className, "w-full sidebar"]}>
    <div class="flex flex-col w-full gap-6 mb-4">
        <Profile></Profile>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-6 sidebar-sticky-scroll">
        <Categories class="onload-animation" style="animation-delay: 150ms"></Categories>
        <Tag class="onload-animation" style="animation-delay: 200ms"></Tag>
    </div>
</div>

<style>
.sidebar {
	padding: 1rem 0;
	height: 100vh;
	overflow: hidden;
	display: flex;
	flex-direction: column;
    }

    .sidebar-sticky-scroll {
	flex: 1;
	min-height: 0;
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
	overflow-y: auto;
	max-height: calc(100vh - 12rem);
	scrollbar-width: thin;
	scrollbar-color: var(--primary) transparent;
	padding-right: 0.25rem;
    }

    .sidebar-sticky-scroll::-webkit-scrollbar {
	width: 4px;
    }

    .sidebar-sticky-scroll::-webkit-scrollbar-track {
	background: transparent;
    }

    .sidebar-sticky-scroll::-webkit-scrollbar-thumb {
	background-color: var(--primary);
	border-radius: 2px;
	opacity: 0.5;
    }

    .sidebar-sticky-scroll:hover::-webkit-scrollbar-thumb {
	opacity: 1;
    }

    /* Mobile responsive - allow full scrollable area */
    @media (max-width: 1023px) {
	.sidebar {
	    padding-bottom: 2rem;
	}

	.sidebar-sticky-scroll {
	    max-height: calc(100vh - 14rem);
	    overflow-y: auto;
	    -webkit-overflow-scrolling: touch;
	}
    }
</style>
