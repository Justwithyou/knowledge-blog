---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
---

<div class="sidebar-profile">
    <!-- Avatar -->
    <a aria-label="Go to About Page" href={url('/about/')} class="profile-avatar-link">
        <div class="profile-avatar">
            <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="profile-avatar-img"></ImageWrapper>
        </div>
    </a>

    <!-- Name & Bio -->
    <div class="profile-info">
        <h2 class="profile-name">{config.name}</h2>
        <p class="profile-bio">{config.bio}</p>
    </div>

    <!-- Social Links -->
    <div class="profile-links">
        {config.links.map(item => (
            <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="profile-link">
                <Icon name={item.icon} class="profile-link-icon"></Icon>
                <span>{item.name}</span>
            </a>
        ))}
        <a rel="me" aria-label="RSS Feed" href={url('/rss.xml')} target="_blank" class="profile-link">
            <Icon name="fa6-solid:rss" class="profile-link-icon"></Icon>
            <span>RSS</span>
        </a>
    </div>
</div>

<style>
    .sidebar-profile {
        padding: 1rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        transition: all 0.3s ease;
    }

    .sidebar-profile:hover {
        border-color: var(--primary);
    }

    .profile-avatar-link {
        display: block;
        margin-bottom: 1rem;
    }

    .profile-avatar {
        width: 4rem;
        height: 4rem;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .profile-avatar:hover {
        border-color: var(--primary);
    }

    .profile-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-info {
        margin-bottom: 1rem;
    }

    .profile-name {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: 600;
        color: var(--text-color);
        margin: 0 0 0.5rem 0;
        transition: all 0.3s ease;
        letter-spacing: -0.01em;
    }

    .profile-avatar-link:hover + .profile-info .profile-name,
    .sidebar-profile:hover .profile-name {
        color: var(--primary);
        text-shadow: 0 0 10px var(--primary);
    }

    .profile-bio {
        font-size: var(--text-sm);
        color: var(--text-muted);
        line-height: var(--leading-relaxed);
        margin: 0;
    }

    .profile-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .profile-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: var(--text-xs);
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
        background: var(--btn-regular-bg);
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .profile-link:hover {
        color: var(--primary);
        background: var(--btn-regular-bg-hover);
        border-color: var(--primary);
    }

    .profile-link-icon {
        font-size: 1rem;
    }
</style>
