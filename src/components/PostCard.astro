---
import type { CollectionEntry } from "astro:content";
import path from "node:path";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { getDir } from "../utils/url-utils";
import PostMetadata from "./PostMeta.astro";

interface Props {
    class?: string;
    entry: CollectionEntry<"posts">;
    title: string;
    url: string;
    published: Date;
    updated?: Date;
    tags: string[];
    category: string | null;
    image: string;
    description: string;
    draft: boolean;
    style: string;
}
const {
    entry,
    title,
    url,
    published,
    updated,
    tags,
    category,
    image,
    description,
    style,
} = Astro.props;
const className = Astro.props.class;

const { remarkPluginFrontmatter } = await entry.render();
---

<div class:list={["post-card", className]} style={style}>
    <a href={url} class="post-card-link">
        <div class="post-card-content">
            <!-- Title with left border accent -->
            <h2 class="post-card-title">
                {title}
            </h2>

            <!-- metadata -->
            <div class="post-card-meta">
                <span class="post-card-date">
                    {published.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
                <span class="post-card-divider">·</span>
                <span class="post-card-reading-time">
                    {remarkPluginFrontmatter.minutes} {i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}
                </span>
                {category && (
                    <>
                        <span class="post-card-divider">·</span>
                        <span class="post-card-category">{category}</span>
                    </>
                )}
            </div>

            <!-- description -->
            <p class="post-card-description">
                {description || remarkPluginFrontmatter.excerpt}
            </p>

            <!-- tags -->
            {tags.length > 0 && (
                <div class="post-card-tags">
                    {tags.slice(0, 3).map(tag => (
                        <span class="post-card-tag">#{tag}</span>
                    ))}
                </div>
            )}
        </div>
    </a>
</div>

<style>
    .post-card {
        position: relative;
        padding: 1.5rem 0 1.5rem 1.5rem;
        border-left: 4px solid var(--border-color);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        margin-left: 0.5rem;
        background: linear-gradient(
            90deg,
            rgba(86, 156, 214, 0.02) 0%,
            transparent 50%
        );
    }

    .post-card::before {
        content: '';
        position: absolute;
        left: -2px;
        top: 0;
        bottom: 0;
        width: 4px;
        background: var(--primary);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 0 2px 2px 0;
    }

    .post-card:hover::before {
        width: 6px;
        box-shadow: 0 0 16px var(--primary);
    }

    .post-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .post-card-content {
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), padding-left 0.4s ease;
        padding-left: 0.5rem;
    }

    .post-card:hover .post-card-content {
        transform: translateX(10px);
        padding-left: 0;
    }

    .post-card-title {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--text-color);
        margin: 0 0 0.75rem 0;
        line-height: var(--leading-snug);
        transition: all 0.3s ease;
        letter-spacing: -0.01em;
    }

    .post-card:hover .post-card-title {
        color: var(--primary);
    }

    .post-card-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: var(--text-sm);
        color: var(--text-muted);
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
    }

    .post-card-divider {
        color: var(--meta-divider);
    }

    .post-card-category {
        color: var(--text-muted);
        font-weight: 500;
    }

    .post-card-description {
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        color: var(--text-muted);
        margin: 0 0 0.75rem 0;
        padding-right: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.3s ease;
    }

    .post-card:hover .post-card-description {
        color: var(--text-color);
    }

    .post-card-tags {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .post-card-tag {
        font-size: var(--text-xs);
        color: var(--text-muted);
        font-family: var(--font-mono);
        transition: all 0.3s ease;
        letter-spacing: 0.02em;
    }

    .post-card:hover .post-card-tag {
        color: var(--primary);
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
        .post-card {
            padding: 1.25rem 0 1.25rem 1rem;
            margin-left: 0;
        }

        .post-card-title {
            font-size: var(--text-lg);
        }
    }
</style>
