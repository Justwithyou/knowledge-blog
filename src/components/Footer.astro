---
import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<footer class="footer">
    <div class="footer-divider"></div>
    <div class="footer-content">
        <div class="footer-copy">
            &copy; {currentYear} {profileConfig.name}. All Rights Reserved.
        </div>
    </div>
</footer>

<style>
    .footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 40;
        width: 100vw;
        background: var(--page-bg);
    }

    .footer-divider {
        width: 100%;
        height: 1px;
        background: var(--border-color);
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem;
    }

    .footer-copy {
        font-size: 0.8rem;
        color: var(--text-muted);
    }
</style>
