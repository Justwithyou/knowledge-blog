/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

/* Deep Black Accent - Fixed color, no hue dependency */
:root
  --primary: #1a1a1a
  --primary-hover: #404040
  --primary-active: #000000

:root.dark
  --primary: #e5e5e5
  --primary-hover: #ffffff
  --primary-active: #d4d4d4

/* Color Scheme - Minimalist Developer Style */
define({
  --page-bg: #fafafa #0a0a0a,
  --page-bg-pure: #ffffff #0f0f0f,
  --card-bg: #ffffff #141414,

  --btn-content: #1a1a1a #e5e5e5,

  --btn-regular-bg: #f5f5f5 #1f1f1f,
  --btn-regular-bg-hover: #e5e5e5 #2a2a2a,
  --btn-regular-bg-active: #d4d4d4 #333333,

  --btn-plain-bg-hover: #f5f5f5 #1a1a1a,
  --btn-plain-bg-active: #e5e5e5 #141414,

  --btn-card-bg-hover: #fafafa #1f1f1f,
  --btn-card-bg-active: #f5f5f5 #2a2a2a,

  --enter-btn-bg: var(--btn-regular-bg),
  --enter-btn-bg-hover: var(--btn-regular-bg-hover),
  --enter-btn-bg-active: var(--btn-regular-bg-active),

  /* Navigation bar buttons */
  --btn-nav-bg: #f5f5f5 #1a1a1a,
  --btn-nav-bg-hover: #e5e5e5 #262626,
  --btn-nav-bg-active: #d4d4d4 #333333,

  /* Category buttons */
  --btn-category-bg: #f5f5f5 #1a1a1a,
  --btn-category-bg-hover: #e5e5e5 #262626,
  --btn-category-bg-active: #d4d4d4 #333333,

  /* Tag buttons */
  --btn-tag-bg: #f5f5f5 #1a1a1a,
  --btn-tag-bg-hover: #e5e5e5 #262626,
  --btn-tag-bg-active: #d4d4d4 #333333,

  --deep-text: #404040 #a3a3a3,

  --title-active: #1a1a1a #e5e5e5,

  --line-divider: black(0.08) white(0.08),

  --line-color: black(0.1) white(0.1),
  --meta-divider: black(0.2) white(0.2),

  --inline-code-bg: var(--btn-regular-bg),
  --inline-code-color: var(--btn-content),
  --selection-bg: rgba(26, 26, 26, 0.12) rgba(229, 229, 229, 0.15),
  --codeblock-selection: rgba(229, 229, 229, 0.15),
  --codeblock-bg: #f5f5f5 #1a1a1a,
  --codeblock-topbar-bg: #e5e5e5 #262626,

  --license-block-bg: black(0.03) #1a1a1a,

  --link-underline: #1a1a1a #e5e5e5,
  --link-hover: #404040 #ffffff,
  --link-active: #000000 #d4d4d4,

  --float-panel-bg: #ffffff #141414,

  --scrollbar-bg-light: black(0.4),
  --scrollbar-bg-hover-light: black(0.5),
  --scrollbar-bg-active-light: black(0.6),

  --scrollbar-bg-dark: white(0.4),
  --scrollbar-bg-hover-dark: white(0.5),
  --scrollbar-bg-active-dark: white(0.6),

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark),
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark),
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark),

  --admonitions-color-tip: #1a1a1a #e5e5e5,
  --admonitions-color-note: #1a1a1a #e5e5e5,
  --admonitions-color-important: #1a1a1a #e5e5e5,
  --admonitions-color-warning: #1a1a1a #e5e5e5,
  --admonitions-color-caution: #1a1a1a #e5e5e5,

  --toc-badge-bg: #f5f5f5 #1f1f1f,
  --toc-btn-hover: #e5e5e5 #262626,
  --toc-btn-active: #d4d4d4 #333333,
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem),
  --toc-item-active: #1a1a1a #e5e5e5,
})

/* Font families - Geist Sans/Mono */
:root
  --font-sans: 'Geist Sans', 'Noto Sans SC', system-ui, -apple-system, sans-serif
  --font-mono: 'Geist Mono', 'JetBrains Mono', 'Fira Code', monospace

:root.font-sans
  --font-body: var(--font-sans)
:root.font-serif
  --font-body: var(--font-sans)
:root.font-mono
  --font-body: var(--font-mono)
:root.font-poppins
  --font-body: var(--font-sans)
:root.font-source-han
  --font-body: var(--font-sans)
:root.font-system
  --font-body: var(--font-sans)
:root.font-lishu
  --font-body: var(--font-sans)
:root.font-kaikai
  --font-body: var(--font-sans)
:root.font-source-code
  --font-body: var(--font-mono)
:root.font-merriweather
  --font-body: var(--font-sans)

body
  font-family: var(--font-body, var(--font-sans))
